# Required
WEATHER_API_KEY=replace-with-your-key

# Optional
APP_ENV=development
WEATHER_API_BASE_URL=https://api.weatherapi.com/v1
WEATHER_API_LANGUAGE=it
# Frontend runtime config for separate static hosting.
# Use /api for same-origin deploys, or a full backend URL like https://your-app.onrender.com/api.
FRONTEND_API_BASE_URL=/api
# Leave empty in production if frontend and backend share the same origin.
# In development, localhost preview ports are allowed automatically when omitted.
CORS_ALLOWED_ORIGINS=
